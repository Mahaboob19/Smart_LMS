{
  "name": "smart-library-lms-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd smart-library-lms && npm install",
    "install-all": "npm run install:backend && npm run install:frontend",
    "build:frontend": "cd smart-library-lms && npm run build",
    "build": "npm run install-all && npm run build:frontend",
    "start": "cd backend && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd smart-library-lms && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
